<!--
    This script is v4 of the API for NZBN. 
    CSSM NZBN has the full JavaScript with names, email, website, phone and address.
-->
<script type="text/javascript">
    $("input[name$='NZBNTextBox']").focusout(function () {

        // Declare TextBox/DropDown names. They are different on each page.
        var nameTextBox = $("input[name$='companyOrganisationTextBox']");

        // Declare error labels.
        var nameErrorLabel = "companyOrganisationErrorLabel";

        if ($("div[id$='NZBNTextBox']").val() == '') {
            $("div[id$=NZBNSearchResult]").html('');
            $("input[name$='NZBNDetailField']").val('');
            $("span[id$=NZBNErrorLabel]").html('');
        }
        else if (!/94[0-9]{11}/.test($("input[name$='NZBNTextBox']").val())) {
            $("div[id$=NZBNSearchResult]").html('');
            $("input[name$='NZBNDetailField']").val('');
            $("span[id$=NZBNErrorLabel]").html('Please enter a valid NZBN. ' +
                'The NZBN should have 13 numbers and begin with 94.');
            logNZBN(400);
        }
        else {
            // Blank out the textboxes as this is a relevent NZBN Number. Each page has different textboxes that need clearing.
            nameTextBox.val('');
            nameTextBox.attr('errorlabel', 'mandatory');

            // Display loading image and clear errors and relevent fields.
            $("img[id$='NZBNLoadingImage']").css("display", "inline-block");
            $("div[id$=NZBNSearchResult]").html('');
            $("input[name$='NZBNDetailField']").val('');
            $("span[id$=NZBNErrorLabel]").html('');

            //debugging info
            var urlField = $("input[name$='AMSNZBNUrlField']").val();
            var keyField = $("input[name$='AMSNZBNKeyField']").val();
            var headerName = $("input[name$='AMSNZBNHeaderName']").val();
            var nzbn = $("input[name$='NZBNTextBox']").val()
            var apiUrl = urlField + nzbn;

            // Make call to api.
            $.ajax({
                url: apiUrl,
                headers: {
                    'Ocp-Apim-Subscription-Key':keyField
                },
                dataType: 'json',
                method: 'GET',
                success: function (result) {
                    $("img[id$='NZBNLoadingImage']").css("display", "none");

                    // Check to see that there is a result. A result will have a NZBN.
                    if (!!result.nzbn) {
                        // Declare privacy variables. False means that it is not private and can be shown to public.
                        var privacyTradeName = false;
                        var privacyEntityName = false;

                        // Name of org.
                        var name;

                        if (!!result.entityStatusCode)
                            // Check to see if registered business.
                            if (result.entityStatusCode == "50") {
                                // Get privacy variables.
                                if (!!result.privacySettings && !!result.privacySettings.tradingNamePrivateInformation && result.privacy.privacySettings.tradingNamePrivateInformation == true) {
                                    privacyTradeName = true;
                                }

                                if (!!result.privacySettings && !!result.privacySettings.namePrivateInformation && result.privacy.privacySettings.namePrivateInformation == true) {
                                    privacyEntityName = true;
                                }

                                // Get Name in priority of tradingName, entityNames, entityName.
                                // Trading Name.
                                if (privacyTradeName == false && !!result.tradingNames[0] && !IsBlank(getMostRecent(result.tradingNames, "tradingNames")) && getMostRecent(result.tradingNames, "tradingNames").toUpperCase() != "NO TRADING NAME") {
                                    var name = getMostRecent(result.tradingNames, "tradingNames");
                                }

                                // Entity Name from Entity Object.
                                else if (privacyEntityName == false && !!result.entityNames && !IsBlank(getMostRecent(result.entityNames, "entityNames")) && getMostRecent(result.entityNames, "entityNames").toUpperCase() != "NO TRADING NAME") {
                                    name = getMostRecent(result.entityNames, "entityNames");
                                }

                                // Entity Name from entityName string.
                                else if (privacyEntityName == false && !!result.entityName && !IsBlank(result.entityName) && result.entityName.toUpperCase() != "NO TRADING NAME") {
                                    name = result.entityName;
                                }

                                // No name */
                                else {
                                    $("div[id$=NZBNSearchResult]").html('');
                                    $("input[name$='NZBNDetailField']").val('no business name available');
                                }

                                $("span[id$=NZBNErrorLabel]").html('');

                                if (!IsBlank(name)) {
                                    nameTextBox.val(name);
                                    $("input[name$='NZBNDetailField']").val(name);
                                    nameTextBox.attr('errorlabel', 'tick');
                                }
                            }

                            else {
                                $("div[id$=NZBNSearchResult]").html('');
                                $("input[name$='NZBNDetailField']").val('');
                                $("span[id$=NZBNErrorLabel]").html('Please enter a valid NZBN. The NZBN should have 13 numbers and begin with 94.');
                                logNZBN(400);
                            }
                    }

                    else {
                        $("div[id$=NZBNSearchResult]").html('');
                        $("input[name$='NZBNDetailField']").val('');
                        $("span[id$=NZBNErrorLabel]").html('Please enter a valid NZBN. The NZBN should have 13 numbers and begin with 94.');
                        logNZBN(400);
                    }
                },
                error: function (result) {
                    $("img[id$='NZBNLoadingImage']").css("display", "none");
                    $("div[id$=NZBNSearchResult]").html('');
                    $("input[name$='NZBNDetailField']").val('');
                    if (result.status != "400" && result.status != "404") {
                        $("span[id$=NZBNErrorLabel]").html('We are unable to validate the NZBN that you have provided at ' +
                            'this time, as the NZBN Register is not responding.');
                    }
                    else {
                        $("span[id$=NZBNErrorLabel]").html('Please enter a valid NZBN. The NZBN should have 13 numbers and begin with 94.');
                    }
                    logNZBN(500);
                }
            });
        }
    });

    function logNZBN(statusCode) {
        var nzbn = $("input[name$='NZBNTextBox']").val();
        var eoiid = $("span[id$='eoiIDLabel']").text();

        $.ajax({
            url: "/CSSM/Wizard/NZBNLog.aspx?EOIId=" + eoiid + "&nzbn=" + nzbn + "&statusCode=" + statusCode,
            method: 'GET', success: function (result) { }
        });
    }

    /**
     * This takes an aray from the json, finds the most recent item in the array and then sends the item we want back.
     * @param objectArray Array inside of a json object. One of TradingName, EntityName, Phone Number, Email, Website or Address.
     * @param item what we are looking for. tradinNames, entityNames, phone number, email, website.
     */
    function getMostRecent(objectArray, item) {
        // Number of items in objectArray
        var length = objectArray.length;
        //string to return
        var result;
        // Sort objectArray by startDate. Most recent first.
        objectArray.sort(compare);
        // Switch using the item we are actually looking for.
        switch (item) {
            case "tradingNames":
                for (j = 0; j < length; ++j) {
                    //if not null or empty then this is the value we want. Otherwise go to next item in array.
                    if (!IsBlank(objectArray[j].name)) {
                        result = objectArray[j].name;
                        break;
                    }
                }
                break;

            case "entityNames":
                for (j = 0; j < length; ++j) {
                    // If not null or empty then this is the value we want. Otherwise go to next item in array.
                    if (!IsBlank(objectArray[j].entityName)) {
                        result = objectArray[j].entityName;
                        break;
                    }
                }
                break;
        }
        return result;
    }

    /**
     * Sort function.
     * @param a
     * @param b
     */
    function compare(a, b) {
        // Use toUpperCase() to ignore character casing
        const startA = a.startDate;
        const startB = b.startDate;
        let comparison = 0;
        if (startA > startB) {
            comparison = -1;
        } else if (startA < startB) {
            comparison = 1;
        }
        return comparison;
    }

    /**
     * Checks to see if string is blank or undefined or null.
     * @param string String to check.
     */
    function IsBlank(string) {
        if (!string || string == undefined || string == "") {
            return true;
        }
        else {
            return false;
        }
    }
</script>

