{
  "manifest_version": 3,
  "name": "NZ Visa Autofill",
  "version": "1.0",
  "description": "Auto-fill the New Zealand Immigration Working Holiday visa application form with saved profile data.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://onlineservices.immigration.govt.nz/WorkingHoliday/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NZ Visa Autofill"
  },
  "content_scripts": [
    {
      "matches": [
        "https://onlineservices.immigration.govt.nz/WorkingHoliday/Wizard/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
